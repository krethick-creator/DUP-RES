# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/ai-recruitment
# If MongoDB is unavailable, the app automatically uses a built-in fallback data store.

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# OpenAI (placeholder)
OPENAI_API_KEY=sk-placeholder-openai-key

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_PAT=ghp_placeholder-personal-access-token

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gmail API
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret

# Microsoft Graph / Outlook
OUTLOOK_CLIENT_ID=your-outlook-client-id
OUTLOOK_CLIENT_SECRET=your-outlook-client-secret

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@recruitment-platform.com

# CSRF
CSRF_SECRET=your-csrf-secret-key
